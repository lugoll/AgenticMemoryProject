# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Data layer — never commit datasets or persisted indices
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/raw/baseline_dummy*
!data/processed/.gitkeep
!data/processed/baseline_dummy*

# Evaluation outputs — generated artifacts, not source
evaluations/*
!evaluations/.gitkeep

# Jupyter
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints/

# Environment & secrets
.env
.env.*
*.secret

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# LlamaIndex / ChromaDB / vector store artifacts
chroma_db/
*.index
*.faiss
*.pkl

# Neo4j local data
neo4j/data/

